# Aike mobile environment (NON-SECRET values only). Copy to `.env` (git-ignored).
#
# The mobile app must NEVER hold secrets. Secret Mapbox/Paystack tokens, webhook secrets,
# VAPID private keys and DB credentials live ONLY in the backend (logistics-app/config/env.php).
#
# For EAS builds these are supplied per profile in eas.json `build.<profile>.env` (or as EAS
# secrets for anything you'd rather not commit); app.config.js injects them into `extra` so
# src/config.ts can read them on device. For local `expo start`, put them in mobile/.env.

# Base URL of the backend JSON API. Use https in production; the EAS profiles override this
# (production → https://entrepoints.ng/api/v1, preview → staging).
AIKE_API_BASE_URL=https://entrepoints.ng/api/v1

# Public Mapbox token (pk.*) — safe on device by design; restrict it to the app bundle id in the
# Mapbox dashboard. The SECRET token (sk.*) is used only server-side for Directions/pricing.
AIKE_MAPBOX_PUBLIC_TOKEN=pk.REPLACE_ME

# Expo / EAS project id (public). Drives EAS Update (OTA) — `https://u.expo.dev/<id>`.
AIKE_EAS_PROJECT_ID=REPLACE_ME

# Google OAuth client IDs (NON-SECRET — the client secret stays server-side). Leave blank to hide
# the "Continue with Google" button. The backend must list these ids in `google_mobile_client_ids`
# so it accepts tokens minted for them (audience pin).
AIKE_GOOGLE_IOS_CLIENT_ID=
AIKE_GOOGLE_ANDROID_CLIENT_ID=
AIKE_GOOGLE_WEB_CLIENT_ID=
