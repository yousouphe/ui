# Aike mobile environment (NON-SECRET values only). Copy to `.env` (git-ignored).
#
# The mobile app must NEVER hold secrets. Secret Mapbox/Paystack tokens, webhook secrets,
# VAPID private keys and DB credentials live ONLY in the backend (logistics-app/config/env.php).

# Base URL of the backend JSON API (Phase 3). Use https in production.
AIKE_API_BASE_URL=https://entrepoints.ng/api/v1

# Public Mapbox token (pk.*) — safe on device by design; restrict it to the app in the Mapbox
# dashboard. The SECRET token (sk.*) is used only server-side for Directions/pricing.
AIKE_MAPBOX_PUBLIC_TOKEN=pk.REPLACE_ME

# Expo push / FCM-APNs project identifiers (public).
AIKE_EAS_PROJECT_ID=REPLACE_ME
